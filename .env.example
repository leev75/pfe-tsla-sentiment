# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit it.

# ── Data paths ────────────────────────────────────────────────────────────────
# Local paths (default — used when not on Kaggle)
LAYER2_PATH=data/raw/layer2/layer2_unified_final.parquet
DAY1_SAMPLE=outputs/data/step2_finbert_sample_results.parquet
OUTPUT_PATH=outputs

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required for higher rate limits when downloading models
HF_TOKEN=your_hf_token_here

# ── Data collection API keys (Step 1 only) ───────────────────────────────────
NEWSAPI_KEY=
FINNHUB_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pfe-tsla-sentiment/1.0
